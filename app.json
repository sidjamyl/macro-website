{
  "expo": {
    "name": "e-tqan",
    "slug": "etqan-prototype",
    "scheme": "etqan",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": ["expo-router"],
    "web": { "bundler": "metro" },
    "experiments": { "typedRoutes": false },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#14496F"
    },
    "ios": { "supportsTablet": true },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": { "backgroundColor": "#14496F" }
    }
  }
}
